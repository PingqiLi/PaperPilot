# Paper Agent v1.0.0

# LLM (Qwen3.5-Plus via Alibaba Cloud Bailian)
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen3.5-plus

# Semantic Scholar API (optional, higher rate limits)
S2_API_KEY=

# Database (SQLite, default path: data/paper_agent.db)
# DATABASE_URL=sqlite:///data/paper_agent.db

# Email (SMTP) — optional, for digest email delivery
# QQ:    SMTP_HOST=smtp.qq.com    SMTP_PORT=587  (use authorization code, not login password)
# 163:   SMTP_HOST=smtp.163.com   SMTP_PORT=587
# Gmail: SMTP_HOST=smtp.gmail.com SMTP_PORT=587  (use app password)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
DIGEST_EMAIL_TO=

# Logging
# LOG_LEVEL=INFO
