# PaperPilot
# All settings can be configured in the WebUI Settings page after startup.
# This file is only needed for Docker deployment or if you prefer env-based config.

# LLM — any OpenAI-compatible API (Alibaba Cloud Bailian, OpenAI, DeepSeek, etc.)
# LLM_API_KEY=
# LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# LLM_MODEL=qwen3.5-plus

# Semantic Scholar API — optional, without it you may hit rate limits
# Get your key at: https://www.semanticscholar.org/product/api#api-key-form
# S2_API_KEY=

# Database
# DATABASE_URL=sqlite:///data/paper_agent.db

# LOG_LEVEL=INFO
